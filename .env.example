# Multi-provider list (comma separated)
# Example: fal_wan,fal_vidu,fal_flux,replicate
PROVIDERS=fal_wan,fal_vidu,fal_flux,replicate

# -------------------------------
# FAL.AI (API key header: Authorization: Key <FAL_KEY>)
# -------------------------------
# Text -> Video (WAN 2.6)
PROVIDER_FAL_WAN_NAME=FAL WAN T2V
PROVIDER_FAL_WAN_API_URL=https://fal.run/wan/v2.6/text-to-video
PROVIDER_FAL_WAN_API_METHOD=POST
PROVIDER_FAL_WAN_API_KEY=
PROVIDER_FAL_WAN_API_AUTH_HEADER=Authorization
PROVIDER_FAL_WAN_API_AUTH_PREFIX=Key
PROVIDER_FAL_WAN_API_HEADERS_JSON={}
PROVIDER_FAL_WAN_API_BODY_TEMPLATE={"prompt":"{{prompt}}"}
PROVIDER_FAL_WAN_API_RESPONSE_VIDEO_URL_PATH=video.url

# Image -> Video (Vidu Q3)
PROVIDER_FAL_VIDU_NAME=FAL Vidu I2V
PROVIDER_FAL_VIDU_API_URL=https://fal.run/fal-ai/vidu/q3/image-to-video
PROVIDER_FAL_VIDU_API_METHOD=POST
PROVIDER_FAL_VIDU_API_KEY=
PROVIDER_FAL_VIDU_API_AUTH_HEADER=Authorization
PROVIDER_FAL_VIDU_API_AUTH_PREFIX=Key
PROVIDER_FAL_VIDU_API_HEADERS_JSON={}
PROVIDER_FAL_VIDU_API_BODY_TEMPLATE={"prompt":"{{prompt}}","image_url":"{{image_data_url}}"}
PROVIDER_FAL_VIDU_API_RESPONSE_VIDEO_URL_PATH=video.url

# Text -> Image (FLUX Schnell)
PROVIDER_FAL_FLUX_NAME=FAL Flux T2I
PROVIDER_FAL_FLUX_API_URL=https://fal.run/fal-ai/flux/schnell
PROVIDER_FAL_FLUX_API_METHOD=POST
PROVIDER_FAL_FLUX_API_KEY=
PROVIDER_FAL_FLUX_API_AUTH_HEADER=Authorization
PROVIDER_FAL_FLUX_API_AUTH_PREFIX=Key
PROVIDER_FAL_FLUX_API_HEADERS_JSON={}
PROVIDER_FAL_FLUX_API_BODY_TEMPLATE={"prompt":"{{prompt}}"}
PROVIDER_FAL_FLUX_API_RESPONSE_IMAGE_URL_PATH=images[0].url

# -------------------------------
# Replicate (API token header: Authorization: Bearer <REPLICATE_API_TOKEN>)
# Note: Replicate is async. You must set MODEL VERSION + output path per model.
# -------------------------------
PROVIDER_REPLICATE_NAME=Replicate
PROVIDER_REPLICATE_API_URL=https://api.replicate.com/v1/predictions
PROVIDER_REPLICATE_API_METHOD=POST
PROVIDER_REPLICATE_API_KEY=
PROVIDER_REPLICATE_API_AUTH_HEADER=Authorization
PROVIDER_REPLICATE_API_AUTH_PREFIX=Bearer
PROVIDER_REPLICATE_API_HEADERS_JSON={}
# Replace YOUR_MODEL_VERSION and input fields per model docs
PROVIDER_REPLICATE_API_BODY_TEMPLATE={"version":"YOUR_MODEL_VERSION","input":{"prompt":"{{prompt}}","image":"{{image_data_url}}"}}
# Async polling
PROVIDER_REPLICATE_API_POLL_URL_TEMPLATE=https://api.replicate.com/v1/predictions/{{id}}
PROVIDER_REPLICATE_API_JOB_ID_PATH=id
PROVIDER_REPLICATE_API_POLL_DONE_PATH=status
PROVIDER_REPLICATE_API_POLL_DONE_VALUE=succeeded
PROVIDER_REPLICATE_API_POLL_INTERVAL_MS=2000
PROVIDER_REPLICATE_API_POLL_MAX_TRIES=60
# Many Replicate models return output as array. Set per model:
# PROVIDER_REPLICATE_API_RESPONSE_VIDEO_URL_PATH=output[0]
# PROVIDER_REPLICATE_API_RESPONSE_IMAGE_URL_PATH=output[0]

# -------------------------------
# Mock provider (optional)
# Add "mock" to PROVIDERS if you want demo output
# -------------------------------
MOCK_VIDEO_URL=
MOCK_IMAGE_URL=

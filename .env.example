# Provider mode: custom or mock
PROVIDER=custom

# Base request
VIDEO_API_URL=
VIDEO_API_METHOD=POST
VIDEO_API_KEY=
VIDEO_API_AUTH_HEADER=Authorization
VIDEO_API_AUTH_PREFIX=Bearer
VIDEO_API_HEADERS_JSON={}

# Request body template (JSON). Available placeholders:
# {{prompt}}, {{mode}}, {{image_base64}}, {{image_mime}}, {{image_data_url}}
VIDEO_API_BODY_TEMPLATE={"prompt":"{{prompt}}","image":"{{image_data_url}}"}

# Where to read the video URL from the response
VIDEO_API_RESPONSE_VIDEO_URL_PATH=videoUrl
VIDEO_API_RESPONSE_IMAGE_URL_PATH=imageUrl

# Optional polling for async providers
VIDEO_API_POLL_URL_TEMPLATE=
VIDEO_API_JOB_ID_PATH=id
VIDEO_API_POLL_DONE_PATH=status
VIDEO_API_POLL_DONE_VALUE=succeeded
VIDEO_API_POLL_INTERVAL_MS=2000
VIDEO_API_POLL_MAX_TRIES=60

# Mock mode
MOCK_VIDEO_URL=
MOCK_IMAGE_URL=
